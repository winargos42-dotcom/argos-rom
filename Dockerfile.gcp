FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi==0.115.0 \
    uvicorn==0.30.0 \
    httpx==0.27.0 \
    anthropic==0.34.0 \
    requests==2.32.0 \
    python-dotenv==1.0.0 \
    pydantic==2.8.0

COPY src/mcp_api_standalone.py src/

ENV ARGOS_ENV=cloud
ENV PORT=8080
EXPOSE 8080

CMD ["python", "-m", "uvicorn", "src.mcp_api_standalone:app", "--host", "0.0.0.0", "--port", "8080"]
